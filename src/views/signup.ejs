<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link
    data-rh="true"
    rel="icon"
    href="https://miro.medium.com/v2/5d8de952517e8160e40ef9841c781cdc14a5db313057fa3c3de41c6f5b494b19"
  />
  <title>Create Account - MediumClone</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    .font-serif-editorial {
      font-family: 'Lora', Georgia, serif;
    }
    .animate-fade-up {
      animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .input-focus:focus {
      border-color: #10b981;
      box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.08);
    }
  </style>
</head>
<body class="bg-slate-50/50 min-h-screen flex flex-col items-center justify-center px-4 relative overflow-hidden">
  <!-- Radial background details -->
  <div class="absolute -right-24 -top-24 w-96 h-96 rounded-full bg-emerald-500/5 blur-3xl"></div>
  <div class="absolute -left-24 -bottom-24 w-96 h-96 rounded-full bg-indigo-500/5 blur-3xl"></div>

  <div class="w-full max-w-[420px] animate-fade-up relative z-10 bg-white border border-slate-100/80 rounded-3xl p-8 sm:p-10 shadow-xl shadow-slate-900/5">
    <!-- Brand Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-slate-950 mb-4 shadow-md shadow-slate-955/20">
        <span class="text-white text-xl font-serif-editorial font-bold">M</span>
      </div>
      <h1 class="text-3xl font-serif-editorial font-bold text-slate-900 mb-2">Create Account</h1>
      <p class="text-slate-450 text-xs sm:text-sm font-serif-editorial italic">Join our publishing community today</p>
    </div>

    <!-- Registration form -->
    <form action="/register" method="POST" class="space-y-4">
      <div class="space-y-3.5">
        <div class="relative">
          <input 
            type="text" 
            name="name" 
            required 
            placeholder="Full name"
            class="w-full px-5 py-3 text-slate-800 bg-slate-55/30 border border-slate-200 rounded-xl focus:outline-none input-focus transition-all duration-200 text-sm"
          />
        </div>

        <div class="relative">
          <input 
            type="text" 
            name="username" 
            required 
            placeholder="Username"
            class="w-full px-5 py-3 text-slate-800 bg-slate-55/30 border border-slate-200 rounded-xl focus:outline-none input-focus transition-all duration-200 text-sm"
          />
        </div>

        <div class="relative">
          <input 
            type="email" 
            name="email" 
            required 
            placeholder="Email address"
            class="w-full px-5 py-3 text-slate-800 bg-slate-55/30 border border-slate-200 rounded-xl focus:outline-none input-focus transition-all duration-200 text-sm"
          />
        </div>

        <div class="relative">
          <input 
            type="password" 
            name="password" 
            required 
            placeholder="Password"
            class="w-full px-5 py-3 text-slate-800 bg-slate-55/30 border border-slate-200 rounded-xl focus:outline-none input-focus transition-all duration-200 text-sm"
          />
        </div>
      </div>

      <button 
        type="submit" 
        class="w-full bg-slate-900 hover:bg-slate-850 text-white text-sm font-semibold py-3 px-6 rounded-xl transition-all duration-200 flex items-center justify-center shadow-lg shadow-slate-950/10 cursor-pointer"
      >
        Create Account
      </button>
    </form>

    <div class="mt-8 text-center space-y-3 border-t border-slate-100 pt-6">
      <p class="text-xs text-slate-500">
        Already have an account? 
        <a href="/login" class="text-emerald-600 hover:text-emerald-700 font-bold transition-all duration-150">Sign In</a>
      </p>
    </div>

    <p class="mt-8 text-center text-[10px] text-slate-400 leading-relaxed">
      By signing up, you agree to our 
      <a href="/terms" class="text-slate-600 hover:underline font-medium">Terms of Service</a>
      and acknowledge our
      <a href="/privacy" class="text-slate-600 hover:underline font-medium">Privacy Policy</a>.
    </p>
  </div>
</body>
</html>