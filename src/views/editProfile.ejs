<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Profile - MediumClone</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link
    data-rh="true"
    rel="icon"
    href="https://miro.medium.com/v2/5d8de952517e8160e40ef9841c781cdc14a5db313057fa3c3de41c6f5b494b19"
  />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link 
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap" 
    rel="stylesheet"
  />
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    .font-serif-editorial {
      font-family: 'Lora', Georgia, serif;
    }
    .input-focus:focus {
      border-color: #10b981;
      box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.08);
    }
  </style>
</head>
<body class="bg-slate-50/50 min-h-screen flex flex-col antialiased">
  <!-- Navbar -->
  <%- include('./partials/navbar.ejs') %>

  <!-- Main Content -->
  <div class="pt-24 px-4 md:px-6 pb-24 flex-grow max-w-2xl mx-auto w-full">
    <div class="bg-white rounded-3xl border border-slate-100 p-8 shadow-sm mb-8">
      <h1 class="text-2xl font-serif-editorial font-bold text-slate-900 mb-6 border-b border-slate-100 pb-3">Edit Profile</h1>
      
      <form action="/user/profile/update" method="POST" enctype="multipart/form-data" class="space-y-6">
        
        <div class="flex justify-center mb-8">
          <div class="relative profile-picture-wrapper group">
            <% if (user.image) { %>
              <img
                class="w-28 h-28 rounded-full object-cover border border-slate-100 ring-4 ring-emerald-500/5 shadow-sm"
                src="data:image/jpeg;base64,<%= user.image.toString('base64') %>"
                alt="Current profile picture"
              />
            <% } else { %>
              <div class="w-28 h-28 rounded-full bg-emerald-50 text-emerald-700 font-bold text-3xl flex items-center justify-center border border-emerald-100 shadow-sm">
                <span>
                  <%= user.username.charAt(0).toUpperCase() %>
                </span>
              </div>
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <!-- Name field -->
          <div>
            <label for="name" class="block text-xs font-bold uppercase tracking-wider text-slate-450 mb-2">
              Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              value="<%= user.name %>"
              class="w-full px-4 py-2.5 text-slate-800 bg-slate-50/50 border border-slate-200 rounded-xl focus:outline-none input-focus text-sm transition-all"
              required
            />
          </div>

          <!-- Username field -->
          <div>
            <label for="username" class="block text-xs font-bold uppercase tracking-wider text-slate-450 mb-2">
              Username
            </label>
            <input
              type="text"
              id="username"
              name="username"
              value="<%= user.username %>"
              class="w-full px-4 py-2.5 text-slate-800 bg-slate-50/50 border border-slate-200 rounded-xl focus:outline-none input-focus text-sm transition-all"
              required
            />
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <!-- Email field -->
          <div>
            <label for="email" class="block text-xs font-bold uppercase tracking-wider text-slate-450 mb-2">
              Email Address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              value="<%= user.email %>"
              class="w-full px-4 py-2.5 text-slate-800 bg-slate-50/50 border border-slate-200 rounded-xl focus:outline-none input-focus text-sm transition-all"
              required
            />
          </div>

          <!-- Password field -->
          <div>
            <label for="password" class="block text-xs font-bold uppercase tracking-wider text-slate-450 mb-2">
              New Password (Optional)
            </label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Leave blank to keep current"
              class="w-full px-4 py-2.5 text-slate-800 bg-slate-50/50 border border-slate-200 rounded-xl focus:outline-none input-focus text-sm transition-all placeholder:text-slate-400"
            />
          </div>
        </div>

        <div class="flex justify-end space-x-3 pt-6 border-t border-slate-100">
          <a
            href="/user/profile"
            class="px-5 py-2.5 border border-slate-200 rounded-xl text-slate-650 hover:bg-slate-50 text-xs font-bold transition-all"
          >
            Cancel
          </a>
          <button
            type="submit"
            class="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold transition-all shadow-sm shadow-emerald-550/10 cursor-pointer"
          >
            Save Changes
          </button>
        </div>
      </form>
    </div>

    <!-- Danger Zone -->
    <div class="bg-white rounded-3xl border border-rose-100 p-8 shadow-sm">
      <h2 class="text-sm font-bold uppercase tracking-wider text-rose-600 mb-2 flex items-center">
        <i class="fas fa-exclamation-triangle mr-2 text-rose-500"></i>
        Danger Zone
      </h2>
      <p class="text-xs text-slate-500 mb-6 leading-relaxed">
        Deleting your account is permanent. This will erase all of your published stories, illustrations, and user information forever.
      </p>
      <a
        href="/user/delete-account/<%= user._id || user.id %>"
        onclick="return confirm('Are you absolutely sure you want to delete your account? This action is irreversible.');"
        class="inline-block px-5 py-2.5 bg-rose-50 hover:bg-rose-100 border border-rose-200/80 text-rose-605 rounded-xl text-xs font-bold transition-colors"
      >
        Delete Account
      </a>
    </div>
  </div>
</body>
</html>