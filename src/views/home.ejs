<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Explore Stories & Ideas - MediumClone</title>
    <link data-rh="true" rel="icon"
      href="https://miro.medium.com/v2/5d8de952517e8160e40ef9841c781cdc14a5db313057fa3c3de41c6f5b494b19"
    />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      .font-serif-editorial {
        font-family: 'Lora', Georgia, serif;
      }
      .hero-gradient {
        background: radial-gradient(circle at 10% 20%, rgba(243, 244, 246, 1) 0%, rgba(255, 255, 255, 1) 90%);
      }
      .post-card-hover {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .post-card-hover:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.05);
        border-color: rgba(226, 232, 240, 0.8);
      }
    </style>
  </head>
  <body class="bg-slate-50/50 text-slate-800 antialiased min-h-screen flex flex-col">
    <%- include('./partials/navbar.ejs') %>

    <!-- Main Container -->
    <main class="flex-grow container mx-auto px-4 md:px-6 lg:px-8 py-12 max-w-6xl mt-16">
      
      <!-- Hero Section -->
      <section class="hero-gradient rounded-3xl border border-slate-100 py-16 px-6 sm:px-12 text-center max-w-5xl mx-auto mb-16 shadow-sm overflow-hidden relative">
        <div class="absolute -right-16 -top-16 w-48 h-48 rounded-full bg-emerald-500/5 blur-3xl"></div>
        <div class="absolute -left-16 -bottom-16 w-48 h-48 rounded-full bg-indigo-500/5 blur-3xl"></div>
        
        <h1 class="text-4xl sm:text-6xl font-serif-editorial font-bold mb-5 tracking-tight text-slate-900 leading-tight">
          Where good ideas <br class="hidden sm:inline" />find their audience.
        </h1>
        <p class="text-lg text-slate-600 max-w-xl mx-auto mb-8 font-serif-editorial italic">
          Discover high-quality articles, thought-provoking essays, and practical expertise from writers on any topic.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/user/posts/all-posts"
            class="w-full sm:w-auto inline-flex items-center justify-center bg-slate-950 text-white py-3.5 px-8 rounded-full text-sm font-semibold hover:bg-slate-850 transition duration-200 shadow-lg shadow-slate-950/10"
          >
            Start Reading
          </a>
          <a
            href="/user/profile"
            class="w-full sm:w-auto inline-flex items-center justify-center bg-white border border-slate-200 text-slate-700 py-3.5 px-8 rounded-full text-sm font-semibold hover:bg-slate-50 transition duration-200"
          >
            Share Your Story
          </a>
        </div>
      </section>

      <!-- Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        
        <!-- Articles Feed -->
        <section class="lg:col-span-8 space-y-8">
          <div class="border-b border-slate-150 pb-4 mb-6 flex items-center justify-between">
            <h2 class="text-xs font-bold uppercase tracking-wider text-slate-400">Featured Stories</h2>
            <div class="h-px bg-slate-200 flex-grow ml-4"></div>
          </div>

          <div class="space-y-6">
            <% articles.forEach(article => { %>
            <article class="bg-white rounded-2xl border border-slate-100 p-6 sm:p-8 post-card-hover shadow-sm">
              <div class="flex items-center space-x-3 text-xs text-slate-400 mb-3.5">
                <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center font-bold text-slate-700 text-[10px]">
                  <%= article.author.charAt(0).toUpperCase() %>
                </div>
                <div>
                  By <span class="font-semibold text-slate-700 hover:text-emerald-600 transition-colors duration-200"><%= article.author %></span>
                </div>
                <span>•</span>
                <div><%= article.date %></div>
              </div>

              <h3 class="text-2xl font-serif-editorial font-bold text-slate-900 mb-3.5 hover:text-emerald-650 transition-colors duration-200 leading-snug">
                <a href="/articles/<%= article.id %>"><%= article.title %></a>
              </h3>
              
              <p class="text-slate-600 text-sm sm:text-base mb-5 leading-relaxed"><%= article.snippet %></p>
              
              <div class="flex items-center justify-between">
                <a
                  href="/articles/<%= article.id %>"
                  class="inline-flex items-center text-xs font-bold text-emerald-600 hover:text-emerald-700 transition-colors duration-200"
                >
                  <span>Read story</span>
                  <i class="fas fa-arrow-right ml-1.5 text-[10px]"></i>
                </a>
                
                <div class="flex items-center space-x-3 text-slate-400">
                  <button class="hover:text-slate-600 transition-colors duration-200 text-xs">
                    <i class="far fa-bookmark"></i>
                  </button>
                  <button class="hover:text-slate-600 transition-colors duration-200 text-xs">
                    <i class="far fa-heart"></i>
                  </button>
                </div>
              </div>
            </article>
            <% }) %>
          </div>
        </section>

        <!-- Sidebar panel -->
        <aside class="lg:col-span-4 space-y-8">
          
          <!-- Tags Card -->
          <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Popular Topics</h3>
            <div class="flex flex-wrap gap-2">
              <% popularTags.forEach(tag => { %>
              <a
                href="/tags/<%= tag %>"
                class="bg-slate-50 hover:bg-slate-100 border border-slate-200/50 text-slate-600 px-3 py-1.5 rounded-full text-xs font-medium transition duration-200 flex items-center"
              >
                <span class="text-emerald-500 mr-1 font-semibold">#</span><%= tag %>
              </a>
              <% }) %>
            </div>
          </div>

          <!-- Recommended Authors Card -->
          <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Recommended Authors</h3>
            <ul class="space-y-4">
              <% authors.forEach(author => { %>
              <li class="flex items-center justify-between group">
                <div class="flex items-center space-x-3">
                  <div class="w-8 h-8 rounded-full bg-emerald-50 text-emerald-700 font-bold text-xs flex items-center justify-center">
                    <%= author.name.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <a href="/authors/<%= author.id %>" class="text-sm font-semibold text-slate-800 hover:text-emerald-650 transition-colors duration-200">
                      <%= author.name %>
                    </a>
                    <p class="text-[10px] text-slate-400">Contributor</p>
                  </div>
                </div>
                <button class="text-[10px] bg-slate-50 hover:bg-emerald-50 hover:text-emerald-600 hover:border-emerald-200 border border-slate-200 font-bold px-3 py-1 rounded-full transition-all duration-200">
                  Follow
                </button>
              </li>
              <% }) %>
            </ul>
          </div>
          
        </aside>
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-150 py-8 text-center text-xs text-slate-400 font-medium">
      <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>&copy; 2026 MediumClone. Designed with visual excellence.</div>
        <div class="flex space-x-4">
          <a href="#" class="hover:text-slate-650 transition-colors duration-200">About</a>
          <a href="#" class="hover:text-slate-650 transition-colors duration-200">Terms</a>
          <a href="#" class="hover:text-slate-650 transition-colors duration-200">Privacy</a>
        </div>
      </div>
    </footer>
  </body>
</html>
