<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>All Stories & Feed - MediumClone</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
      data-rh="true"
      rel="icon"
      href="https://miro.medium.com/v2/5d8de952517e8160e40ef9841c781cdc14a5db313057fa3c3de41c6f5b494b19"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link 
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap" 
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      .font-serif-editorial {
        font-family: 'Lora', Georgia, serif;
      }
      .post-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .post-card:hover {
        transform: translateY(-1px);
        box-shadow: 0 16px 32px -16px rgba(0, 0, 0, 0.06);
        border-color: rgba(226, 232, 240, 0.8);
      }
      .btn-action-hover {
        transition: all 0.2s ease-in-out;
      }
      .btn-action-hover:hover {
        background-color: rgba(248, 250, 252, 0.8);
      }
      .time-ago {
        opacity: 0.8;
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: #f8fafc;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 9999px;
      }
    </style>
  </head>
  <body class="bg-slate-50/50 text-slate-800 antialiased min-h-screen custom-scrollbar flex flex-col">
    <%- include ('./partials/navbar') %>

    <div class="max-w-2xl mx-auto p-4 md:p-6 relative top-16 w-full flex-grow pb-24">
      <header class="mb-10 mt-6 text-center">
        <h1 class="text-3xl font-serif-editorial font-bold text-slate-900 tracking-tight mb-2">
          Discover Stories
        </h1>
        <p class="text-sm text-slate-500 font-serif-editorial italic">See what everyone is writing and sharing right now</p>
      </header>

      <% if (posts.length === 0) { %>
      <div class="bg-white rounded-3xl border border-slate-100 p-12 text-center shadow-sm max-w-md mx-auto">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-50 text-emerald-600 mb-6">
          <i class="fas fa-feather text-2xl"></i>
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">No stories yet</h3>
        <p class="text-sm text-slate-500 mb-6">
          Be the first one to share an inspiring thought or story with the community!
        </p>
        <a
          href="/user/profile"
          class="inline-block bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold px-5 py-2.5 rounded-full transition duration-200 shadow-lg shadow-emerald-650/15"
        >
          Publish First Post
        </a>
      </div>
      <% } else { %> 
      
      <div class="space-y-6">
        <% posts.forEach(post => { %>
        <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden post-card shadow-sm">
          
          <!-- User header -->
          <div class="p-5 pb-3.5 flex items-center space-x-4">
            <a href="/user/profile/<%= post.owner._id %>" class="flex-shrink-0">
              <% if (post.owner.image) { %>
              <img
                class="w-11 h-11 rounded-full object-cover border border-slate-100 ring-2 ring-emerald-500/10 hover:ring-emerald-500/30 transition-all duration-200"
                src="data:image/jpeg;base64,<%= post.owner.image.toString('base64') %>"
                alt="<%= post.owner.username %>'s Avatar"
              />
              <% } else { %>
              <div
                class="w-11 h-11 rounded-full bg-emerald-50 text-emerald-700 font-bold text-base flex items-center justify-center border border-emerald-100"
              >
                <span><%= post.owner.username.charAt(0).toUpperCase() %></span>
              </div>
              <% } %>
            </a>

            <div class="flex-grow min-w-0">
              <a
                href="/user/profile/<%= post.owner._id %>"
                class="font-semibold text-sm text-slate-800 hover:text-emerald-600 transition-colors duration-150 block truncate"
                ><%= post.owner.username %></a
              >

              <div class="flex items-center text-xs text-slate-450 space-x-1.5 mt-0.5">
                <% const now = new Date(); const postDate = new
                Date(post.createdAt); const diffMs = now - postDate; const
                diffSec = Math.floor(diffMs / 1000); const diffMin =
                Math.floor(diffSec / 60); const diffHours = Math.floor(diffMin /
                60); const diffDays = Math.floor(diffHours / 24); let timeAgo; if
                (diffSec < 60) { timeAgo = `${diffSec}s ago`; } else if (diffMin < 60) { timeAgo = `${diffMin}m ago`; } else if (diffHours < 24)
                { timeAgo = `${diffHours}h ago`; } else if (diffDays < 7) { timeAgo = `${diffDays}d ago`; } else { timeAgo =
                postDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }); } %>
                <span class="font-medium text-slate-400"><%= timeAgo %></span>
                <span class="text-slate-300">•</span>
                <span title="<%= postDate.toLocaleString() %>" class="text-slate-400">
                  <%= postDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                </span>
              </div>
            </div>

            <!-- Follow / Following button -->
            <div class="flex-shrink-0">
              <% if (String(post.owner._id) !== String(userId)) { %>
              <button
                id="followBtn-<%= post.owner._id %>"
                onclick="followUser('<%= post.owner._id %>')"
                class="text-xs font-bold px-3.5 py-1.5 rounded-full border transition-all duration-200 <%= following.includes(String(post.owner._id)) ? 'bg-slate-50 text-slate-500 border-slate-200' : 'bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border-emerald-100' %>"
              >
                <% if (!following.includes(String(post.owner._id))) { %>
                <i class="fa-solid fa-user-plus mr-1"></i> Follow
                <% } else { %>
                <i class="fa-solid fa-user-check mr-1"></i> Following
                <% } %>
              </button>
              <% } %>
            </div>
          </div>

          <!-- Post Content -->
          <div class="px-5 py-2">
            <p class="text-slate-800 text-sm sm:text-base leading-relaxed whitespace-pre-line font-serif-editorial"><%= post.content %></p>
          </div>

          <!-- Attached Image -->
          <% if (post.image) { %>
          <div class="px-5 py-3">
            <div class="relative rounded-2xl overflow-hidden bg-slate-50 border border-slate-100/50 shadow-sm max-h-[460px] flex items-center justify-center">
              <img
                class="w-full h-full object-cover max-h-[450px]"
                src="data:image/jpeg;base64,<%= post.image.toString('base64') %>"
                alt="Story Image"
                loading="lazy"
              />
            </div>
          </div>
          <% } %>

          <!-- Post stats summary -->
          <div class="px-5 py-2.5 flex items-center justify-between text-xs text-slate-400 font-medium">
            <div class="flex items-center space-x-4">
              <div class="flex items-center space-x-1">
                <span class="w-5 h-5 rounded-full bg-rose-50 text-rose-500 flex items-center justify-center text-[10px]">
                  <i class="fas fa-heart"></i>
                </span>
                <span id="like-count-<%= post._id %>" class="text-slate-600 font-semibold"><%= post.likes.length || 0 %></span>
              </div>

              <div class="flex items-center space-x-1">
                <span class="w-5 h-5 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center text-[10px]">
                  <i class="fas fa-comment"></i>
                </span>
                <span class="text-slate-600 font-semibold"><%= post.comment ? post.comment.length : 0 %></span>
              </div>
            </div>
          </div>

          <!-- Action buttons (Like, Comment, Share) -->
          <div class="grid grid-cols-3 border-t border-slate-100 bg-slate-50/20 text-xs font-semibold text-slate-650">
            <button
              id="<%= post._id %>-like"
              onclick="likePost('<%= post._id %>')"
              class="btn-action-hover py-3.5 flex items-center justify-center space-x-2 transition-all duration-200 text-slate-650"
            >
              <% if (post.likes.indexOf(userId) !== -1) { %>
              <span class="text-rose-600 flex items-center justify-center"><i class="fas fa-heart mr-2 text-rose-500"></i>Liked</span>
              <% } else { %>
              <span class="text-slate-600 flex items-center justify-center"><i class="far fa-heart mr-2 text-slate-400"></i>Like</span>
              <% } %>
            </button>

            <a
              href="/user/posts/comment/<%= post._id %>"
              class="btn-action-hover py-3.5 flex items-center justify-center space-x-2 text-slate-650 text-center"
            >
              <i class="far fa-comment text-emerald-500 mr-1.5"></i>
              <span class="text-slate-600">Comment</span>
            </a>

            <!-- Share Action dropdown -->
            <div class="relative flex justify-center items-center">
              <button 
                onclick="toggleShareMenu('<%= post._id %>')"
                class="btn-action-hover w-full h-full py-3.5 flex items-center justify-center space-x-2 text-slate-650"
              >
                <i class="fas fa-share-alt text-indigo-500 mr-1.5"></i>
                <span class="text-slate-600">Share</span>
              </button>

              <div
                id="shareMenu-<%= post._id %>"
                class="hidden absolute bottom-12 right-2 bg-white border border-slate-100 rounded-xl shadow-lg z-10 w-44 p-1.5 animate-fade-in"
              >
                <a
                  href="https://www.facebook.com/sharer/sharer.php?u=https://yourwebsite.com/post/<%= post._id %>"
                  target="_blank"
                  class="flex items-center space-x-2 px-3 py-2 text-[11px] text-slate-700 hover:bg-slate-50 rounded-lg transition-colors font-medium"
                >
                  <i class="fab fa-facebook text-blue-600 text-sm"></i>
                  <span>Facebook</span>
                </a>
                <a
                  href="https://twitter.com/intent/tweet?url=https://yourwebsite.com/post/<%= post._id %>&text=<%= encodeURIComponent(post.content.substring(0, 100)) %>"
                  target="_blank"
                  class="flex items-center space-x-2 px-3 py-2 text-[11px] text-slate-700 hover:bg-slate-50 rounded-lg transition-colors font-medium"
                >
                  <i class="fab fa-twitter text-sky-500 text-sm"></i>
                  <span>Twitter</span>
                </a>
                <a
                  href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(post.content.substring(0, 100)) %>%20https://yourwebsite.com/post/<%= post._id %>"
                  target="_blank"
                  class="flex items-center space-x-2 px-3 py-2 text-[11px] text-slate-700 hover:bg-slate-50 rounded-lg transition-colors font-medium"
                >
                  <i class="fab fa-whatsapp text-emerald-500 text-sm"></i>
                  <span>WhatsApp</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Preview of Latest Comment -->
          <% if (post.comment && post.comment.length > 0) { %>
          <div class="px-5 py-4 bg-slate-50/50 border-t border-slate-100">
            <div class="flex items-start space-x-3 mb-2.5">
              <% const lastComment = post.comment[post.comment.length - 1]; %>
              <% const commenter = lastComment.commentedBy || {}; %>
              <% if (commenter.image) { %>
              <img
                src="data:image/jpeg;base64,<%= commenter.image.toString('base64') %>"
                class="w-7 h-7 rounded-full object-cover border border-slate-200"
                alt="Commenter"
              />
              <% } else { %>
              <div
                class="w-7 h-7 rounded-full bg-slate-200 text-slate-700 font-bold text-[10px] flex items-center justify-center"
              >
                <span><%= commenter.username ? commenter.username.charAt(0).toUpperCase() : 'C' %></span>
              </div>
              <% } %>
              
              <div class="bg-white border border-slate-100 rounded-2xl px-4 py-2.5 flex-grow shadow-sm">
                <div class="font-semibold text-xs text-slate-800">
                  <%= commenter.username ? commenter.username : 'Anonymous' %>
                </div>
                <p class="text-xs text-slate-600 mt-1 leading-relaxed">
                  <%= lastComment.text %>
                </p>
              </div>
            </div>
            
            <a
              href="/user/posts/comment/<%= post._id %>"
              class="text-xs text-emerald-600 hover:text-emerald-700 font-bold flex items-center space-x-1 pl-10"
            >
              <span>View all comments</span>
              <i class="fas fa-chevron-right text-[8px]"></i>
            </a>
          </div>
          <% } %>
        </div>
        <% }); %>
      </div>

      <!-- Load More Button -->
      <% if (posts.length >= 10) { %>
      <div class="text-center mt-10">
        <button
          id="load-more"
          class="bg-white hover:bg-slate-50 text-slate-700 font-semibold px-6 py-2.5 rounded-full border border-slate-200/80 shadow-sm transition duration-200 text-xs"
        >
          Load More
        </button>
      </div>
      <% } %> 
      <% } %>
    </div>

    <!-- Interactive script -->
    <script>
      function toggleShareMenu(postId) {
        const menu = document.getElementById(`shareMenu-${postId}`);
        if (menu.classList.contains('hidden')) {
          // Close all other share menus first
          document.querySelectorAll("[id^='shareMenu-']").forEach(el => el.classList.add('hidden'));
          menu.classList.remove('hidden');
        } else {
          menu.classList.add('hidden');
        }
      }

      // Close share menu clicking outside
      window.addEventListener('click', (e) => {
        if (!e.target.closest('.relative')) {
          document.querySelectorAll("[id^='shareMenu-']").forEach(el => el.classList.add('hidden'));
        }
      });

      async function followUser(userId) {
        try {
          const res = await fetch(`/user/handle-follow/${userId}`);
          const data = await res.json();
          const following = data.following;

          // Find all follow buttons for this user (there might be multiple posts by the same user)
          const btns = document.querySelectorAll(`[id^='followBtn-${userId}']`);

          btns.forEach(btn => {
            if (!following.includes(userId)) {
              btn.innerHTML = `<i class="fa-solid fa-user-plus mr-1"></i> Follow`;
              btn.className = "text-xs font-bold px-3.5 py-1.5 rounded-full border transition-all duration-200 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border-emerald-100";
            } else {
              btn.innerHTML = `<i class="fa-solid fa-user-check mr-1"></i> Following`;
              btn.className = "text-xs font-bold px-3.5 py-1.5 rounded-full border transition-all duration-200 bg-slate-50 text-slate-500 border-slate-200";
            }
          });
        } catch (err) {
          console.error("Follow action failed", err);
        }
      }

      async function likePost(postId) {
        try {
          const response = await fetch(`/user/posts/all-posts/like/${postId}`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
          });

          const data = await response.json();
          if (response.ok) {
            const countEl = document.getElementById(`like-count-${postId}`);
            countEl.textContent = data.likes;
            
            let btn = document.getElementById(`${postId}-like`);
            if (data.liked) {
              btn.innerHTML =
                '<span class="text-rose-600 flex items-center justify-center"><i class="fas fa-heart mr-2 text-rose-500 animate-pulse"></i>Liked</span>';
            } else {
              btn.innerHTML =
                '<span class="text-slate-600 flex items-center justify-center"><i class="far fa-heart mr-2 text-slate-400"></i>Like</span>';
            }
          } else {
            console.error("Failed to like post");
          }
        } catch (err) {
          console.error("Error:", err);
        }
      }
    </script>
  </body>
</html>
