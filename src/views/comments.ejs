<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      data-rh="true"
      rel="icon"
      href="https://miro.medium.com/v2/5d8de952517e8160e40ef9841c781cdc14a5db313057fa3c3de41c6f5b494b19"
    />
    <link 
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap" 
      rel="stylesheet"
    />
    <title>Discussions & Comments - MediumClone</title>
    <style>
      body {
        font-family: 'Inter', sans-serif;
        padding-bottom: 90px;
      }
      .font-serif-editorial {
        font-family: 'Lora', Georgia, serif;
      }
      .comments-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: #f8fafc;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 9999px;
      }
    </style>
  </head>
  <body class="bg-slate-50/50 text-slate-800 antialiased custom-scrollbar">
    <%- include('./partials/navbar.ejs') %>

    <!-- Post details & comments feed -->
    <div class="max-w-2xl mx-auto p-4 relative top-16">
      
      <!-- Parent Post card -->
      <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden shadow-sm mb-8 mt-6">
        
        <!-- Post Header -->
        <div class="p-5 pb-3 flex items-center space-x-4">
          <a href="/user/profile/<%= post.owner._id %>" class="flex-shrink-0">
            <% if (post.owner.image) { %>
            <img
              class="w-11 h-11 rounded-full object-cover border border-slate-100 ring-2 ring-emerald-500/10"
              src="data:image/jpeg;base64,<%= post.owner.image.toString('base64') %>"
              alt="Author"
            />
            <% } else { %>
            <div
              class="w-11 h-11 rounded-full bg-emerald-50 text-emerald-700 font-bold text-base flex items-center justify-center border border-emerald-100"
            >
              <span><%= post.owner.username.charAt(0).toUpperCase() %></span>
            </div>
            <% } %>
          </a>

          <!-- Username & Time -->
          <div class="flex-grow">
            <a
              href="/user/profile/<%= post.owner._id %>"
              class="font-semibold text-sm text-slate-800 hover:text-emerald-600 transition-colors"
              ><%= post.owner.username %></a
            >
            <div class="text-xs text-slate-400 mt-0.5">
              <% const now = new Date(); const postDate = new
              Date(post.createdAt); const diffSec = Math.floor((now - postDate)
              / 1000); const diffMin = Math.floor(diffSec / 60); const diffHours
              = Math.floor(diffMin / 60); const diffDays = Math.floor(diffHours
              / 24); let timeAgo = diffSec < 60 ? `${diffSec}s ago` : diffMin <
              60 ? `${diffMin}m ago` : diffHours < 24 ? `${diffHours}h ago` :
              diffDays < 7 ? `${diffDays}d ago` : postDate.toLocaleDateString();
              %>
              <i class="far fa-clock mr-1 text-slate-350"></i> <%= timeAgo %>
              <span class="mx-1.5">•</span>
              <span class="text-slate-400"><%= postDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            </div>
          </div>
        </div>

        <!-- Post Content -->
        <div class="px-5 py-3">
          <p class="text-slate-800 text-sm sm:text-base leading-relaxed whitespace-pre-line font-serif-editorial"><%= post.content %></p>
        </div>

        <!-- Post Image -->
        <% if (post.image) { %>
        <div class="px-5 py-3">
          <div class="relative rounded-2xl overflow-hidden bg-slate-50 border border-slate-100/50 shadow-sm max-h-[360px] flex items-center justify-center">
            <img
              class="w-full h-full object-cover max-h-[350px]"
              src="data:image/jpeg;base64,<%= post.image.toString('base64') %>"
              alt="Post Image"
            />
          </div>
        </div>
        <% } %>

        <!-- Likes & Comments count footer -->
        <div
          class="px-5 py-2.5 border-t border-slate-100 text-xs text-slate-450 flex justify-between bg-slate-50/20"
        >
          <div>
            <button
              id="<%= post._id %>-like"
              onclick="likePost('<%= post._id %>')"
              class="flex items-center text-slate-650 hover:text-rose-500 transition-colors font-bold"
            >
              <% if (post.likes.indexOf(userId) !== -1) { %>
              <i class="fas fa-heart text-rose-500 mr-1.5"></i>
              <% } else { %>
              <i class="far fa-heart text-slate-450 mr-1.5"></i>
              <% } %>
              <span id="like-count-<%= post._id %>" class="text-slate-700 font-semibold"
                ><%= post.likes.length || 0 %></span
              >
            </button>
          </div>
          <div class="font-semibold text-slate-600">
            <i class="far fa-comment text-emerald-500 mr-1.5"></i><span id="postCommentCount" class="font-bold text-slate-700"><%=
            post.comment.length %></span> discussions
          </div>
        </div>
      </div>

      <!-- Discussions Section Title -->
      <h2 class="text-base font-serif-editorial font-bold mb-4 text-slate-900 border-b border-slate-100 pb-2">Discussions</h2>

      <!-- Comments Container -->
      <div
        class="mb-10 space-y-4"
        data-post-id="<%= post._id %>"
        id="comment-Container"
      ></div>

      <!-- Floating glass uploader form -->
      <div
        class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md px-4 py-3.5 border-t border-slate-150 z-50 shadow-lg"
      >
        <div class="max-w-2xl mx-auto">
          <form
            action="/user/posts/comment/add/<%= post._id %>"
            method="POST"
            id="comment-form"
            data-post-id="<%= post._id %>"
            class="flex items-center space-x-3"
          >
            <textarea
              name="content"
              rows="1"
              required
              placeholder="Join the discussion..."
              class="flex-grow resize-none border border-slate-205 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:ring-2 focus:ring-emerald-550/10 focus:border-emerald-500 text-slate-700 leading-relaxed bg-slate-50/50 focus:bg-white transition-all"
            ></textarea>
            <button
              type="submit"
              class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold px-5 py-2.5 rounded-xl transition-all duration-200 shadow-sm shadow-emerald-500/10 cursor-pointer"
            >
              Post
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Scripts -->
    <script>
      document
        .getElementById("comment-form")
        .addEventListener("submit", async (e) => {
          e.preventDefault();
          const postId = e.target.dataset.postId;
          const content = e.target.elements.content.value;

          const res = await fetch("/user/posts/comment/add/" + postId, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ content }),
          });

          const response = await res.json();
          if (response.message === "Comment Added Successfully") {
            let count = document.getElementById("postCommentCount");
            count.innerText = parseInt(count.innerText) + 1;
            renderComments();
            e.target.reset();
          }
        });

      async function renderComments() {
        let commentBox = document.getElementById("comment-Container");
        const postId = commentBox.dataset.postId;

        try {
          const response = await fetch(`/user/posts/all-comments/${postId}`);
          const data = await response.json();

          renderCommentsUI(data.post.comment, commentBox);
        } catch (error) {
          console.error("Failed to fetch comments:", error);
        }
      }

      function renderCommentsUI(comments, container) {
        container.innerHTML = "";

        if (comments.length === 0) {
          container.innerHTML = `
            <div class="text-center py-8 text-slate-400 bg-white border border-slate-100 rounded-2xl p-6">
              <i class="far fa-comments text-2xl mb-2 text-slate-300"></i>
              <p class="text-xs">No comments yet. Start the discussion!</p>
            </div>
          `;
          return;
        }

        comments.forEach((comment) => {
          const commentDiv = document.createElement("div");
          commentDiv.classList.add("bg-white", "p-4", "rounded-2xl", "border", "border-slate-100", "shadow-sm", "comments-card");

          const commenter = comment.commentedBy || { username: 'Anonymous' };
          const avatarHTML = commenter.image
            ? `<img src="data:image/jpeg;base64,${commenter.image.toString('base64')}" class="w-7 h-7 rounded-full object-cover border border-slate-200" alt="Avatar"/>`
            : `<div class="w-7 h-7 rounded-full bg-emerald-50 text-emerald-700 font-bold text-[10px] flex items-center justify-center border border-emerald-100">
                <span>${commenter.username.charAt(0).toUpperCase()}</span>
               </div>`;

          commentDiv.innerHTML = `
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0 mt-0.5">
                ${avatarHTML}
              </div>
              <div class="flex-grow min-w-0">
                <div class="flex items-center space-x-2">
                  <span class="text-xs font-semibold text-slate-800">@${commenter.username}</span>
                  <span class="text-slate-300 text-[10px]">•</span>
                  <span class="text-[10px] text-slate-400 font-medium">
                    ${new Date(comment.commentedAt).toLocaleDateString('en-US', {
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                </div>
                <p class="text-slate-700 text-xs sm:text-sm mt-1.5 leading-relaxed font-serif-editorial">${comment.text}</p>
              </div>
            </div>
          `;

          container.appendChild(commentDiv);
        });
      }

      document.addEventListener("DOMContentLoaded", async () => {
        renderComments();
      });

      async function likePost(postId) {
        try {
          const response = await fetch(`/user/posts/all-posts/like/${postId}`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
          });

          const data = await response.json();
          if (response.ok) {
            const countEl = document.getElementById(`like-count-${postId}`);
            countEl.textContent = data.likes;
            
            let btn = document.getElementById(`${postId}-like`);
            if (data.liked) {
              btn.innerHTML = `<i class="fas fa-heart text-rose-500 mr-1.5 animate-pulse"></i><span id="like-count-${postId}" class="text-slate-700 font-semibold">${data.likes}</span>`;
            } else {
              btn.innerHTML = `<i class="far fa-heart text-slate-450 mr-1.5"></i><span id="like-count-${postId}" class="text-slate-700 font-semibold">${data.likes}</span>`;
            }
          } else {
            console.error("Failed to like post");
          }
        } catch (err) {
          console.error("Error:", err);
        }
      }
    </script>
  </body>
</html>
