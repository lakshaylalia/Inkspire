<nav class="backdrop-blur-md bg-white/80 border-b border-slate-100 fixed top-0 w-full z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      
      <!-- Left side: Brand Logo & Links -->
      <div class="flex items-center space-x-8">
        <a href="/" class="flex items-center space-x-2 text-2xl font-black tracking-tight text-slate-900 hover:opacity-90 transition-opacity">
          <span class="bg-slate-900 text-white w-8 h-8 rounded-lg flex items-center justify-center font-serif text-lg shadow-sm">M</span>
          <span class="font-serif font-semibold text-xl tracking-tight hidden sm:inline-block">MediumClone</span>
        </a>
        
        <!-- Main Navigation Links -->
        <div class="hidden md:flex items-center space-x-6">
          <a href="/" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors duration-200">
            Home
          </a>
          <a href="/user/posts/all-posts" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors duration-200">
            All Posts
          </a>
          
          <% if (typeof User !== 'undefined' && User && User.isAdmin) { %>
            <a href="/admin" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 transition-colors duration-200 flex items-center space-x-1">
              <span class="inline-block w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
              <span>Admin Panel</span>
            </a>
          <% } %>
        </div>
      </div>

      <!-- Right side: Search & User Controls -->
      <div class="flex items-center space-x-4">
        <!-- Interactive Search Bar -->
        <div class="relative hidden sm:block">
          <input 
            type="text" 
            placeholder="Search stories..." 
            class="w-48 md:w-64 pl-9 pr-4 py-1.5 text-sm bg-slate-50 border border-slate-200 rounded-full focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 focus:bg-white transition-all duration-300"
          />
          <i class="fas fa-search absolute left-3.5 top-2.5 text-slate-400 text-xs"></i>
        </div>

        <button class="sm:hidden text-slate-600 hover:text-slate-900 p-2 transition-colors">
          <i class="fas fa-search text-lg"></i>
        </button>

        <% if (typeof User !== 'undefined' && User) { %>
          <!-- Write Button -->
          <a
            href="/user/profile"
            class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold px-4 py-2 rounded-full transition-all duration-200 shadow-sm shadow-emerald-500/10 flex items-center space-x-1.5"
          >
            <i class="far fa-edit"></i>
            <span>Write</span>
