<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= user.name %> (@<%= user.username %>) - MediumClone</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      data-rh="true"
      rel="icon"
      href="https://miro.medium.com/v2/5d8de952517e8160e40ef9841c781cdc14a5db313057fa3c3de41c6f5b494b19"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      .font-serif-editorial {
        font-family: 'Lora', Georgia, serif;
      }
      .profile-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .hover-scale {
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .hover-scale:hover {
        transform: translateY(-2px);
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: #f8fafc;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 9999px;
      }
      .file-input-wrapper {
        position: relative;
        overflow: hidden;
        display: inline-block;
      }
      .file-input-wrapper input[type="file"] {
        position: absolute;
        font-size: 100px;
        opacity: 0;
        right: 0;
        top: 0;
        cursor: pointer;
      }
    </style>
  </head>
  <body class="bg-slate-50/50 text-slate-800 antialiased custom-scrollbar min-h-screen flex flex-col">
    <%- include("./partials/navbar.ejs") %>

    <div class="max-w-4xl mx-auto px-4 py-8 sm:px-6 lg:px-8 relative top-20 flex-grow pb-24 w-full">
      
      <!-- Profile Details Card -->
      <div class="bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm mb-8 profile-card">
        <div class="bg-gradient-to-r from-emerald-500/10 via-teal-500/5 to-indigo-500/10 h-32 sm:h-44 relative">
          <!-- Abstract overlay accent -->
          <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
        </div>
        
        <div class="px-6 sm:px-8 pb-6 sm:pb-8 relative">
          <div class="flex flex-col sm:flex-row -mt-16 sm:-mt-20 sm:items-end">
            <!-- User avatar -->
            <div class="flex-shrink-0 relative z-10 self-center sm:self-auto">
              <img
                id="profile-image"
                src="<%= imageBase64 ? 'data:image/jpeg;base64,' + imageBase64 : 'https://miro.medium.com/v2/5d8de952517e8160e40ef9841c781cdc14a5db313057fa3c3de41c6f5b494b19' %>"
                alt="<%= user.name %>"
                class="rounded-full border-4 border-white w-28 h-28 sm:w-36 sm:h-36 object-cover shadow-md transition-all duration-300 ring-4 ring-emerald-500/5"
              />

              <div
                onclick="document.getElementById('image-input').click();"
                class="absolute -bottom-1 -right-1 w-9 h-9 bg-emerald-600 hover:bg-emerald-700 rounded-full flex items-center justify-center shadow-lg cursor-pointer transition-all duration-200"
              >
                <i class="fas fa-camera text-white text-xs"></i>
              </div>
            </div>

            <!-- Profile identity -->
            <div class="mt-6 sm:mt-0 sm:ml-8 flex-1 text-center sm:text-left">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                  <h1 class="text-2xl sm:text-3xl font-serif-editorial font-bold text-slate-900 tracking-tight">
                    <%= user.name %>
                  </h1>
                  <p class="text-emerald-600 font-semibold text-sm mt-0.5">@<%= user.username %></p>
                </div>
                <div class="flex justify-center">
                  <a
                    href="/user/edit-profile"
                    class="bg-slate-900 hover:bg-slate-800 text-white text-xs font-semibold py-2.5 px-5 rounded-full transition-all duration-200 shadow-sm"
                  >
                    Edit Profile
                  </a>
                </div>
              </div>

              <!-- Stats bar -->
              <div class="flex items-center justify-center sm:justify-start space-x-8 mt-6 border-t border-slate-100 pt-4">
                <div class="text-center sm:text-left">
                  <span class="block text-lg font-bold text-slate-800"><%= user.followers.length %></span>
                  <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Followers</span>
                </div>

                <div class="text-center sm:text-left">
                  <span class="block text-lg font-bold text-slate-800"><%= user.following.length %></span>
                  <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Following</span>
                </div>

                <div class="text-center sm:text-left">
                  <span class="block text-lg font-bold text-slate-800"><%= user.posts ? user.posts.length : 0 %></span>
                  <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Posts</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Panel Grid -->
      <div class="grid gap-6 md:grid-cols-12 mb-8">
        
        <!-- Left Action: Photo Uploader -->
        <div class="md:col-span-5 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm hover-scale">
          <h2 class="text-sm font-bold uppercase tracking-wider text-slate-450 mb-4 flex items-center">
            <i class="far fa-user-circle text-emerald-500 mr-2 text-base"></i>
            Profile Picture
          </h2>

          <form enctype="multipart/form-data" id="update-image-form">
            <div class="mb-5">
              <div class="file-input-wrapper w-full">
                <div
                  class="border-2 border-dashed border-slate-200 rounded-2xl p-6 text-center hover:border-emerald-400 hover:bg-slate-50/50 transition-all cursor-pointer bg-slate-50/20"
                >
                  <i class="fas fa-cloud-upload-alt text-slate-350 text-2xl mb-2"></i>
                  <p class="text-xs font-semibold text-slate-700 block">
                    Choose avatar image
                  </p>
                  <p class="text-[10px] text-slate-400 mt-1">
                    PNG, JPG, or JPEG up to 5MB
                  </p>
                  <input
                    type="file"
                    name="image"
                    accept="image/*"
                    id="image-input"
                  />
                </div>
              </div>
            </div>

            <button
              type="submit"
              class="w-full bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold py-3 px-4 rounded-xl transition-all flex items-center justify-center space-x-1.5 shadow-sm"
            >
              <i class="fas fa-upload text-[10px]"></i>
              <span>Upload Picture</span>
            </button>
          </form>
        </div>

        <!-- Right Action: Create Story Post -->
        <div class="md:col-span-7 bg-white p-6 rounded-2xl border border-slate-100 shadow-sm hover-scale">
          <h2 class="text-sm font-bold uppercase tracking-wider text-slate-450 mb-4 flex items-center">
            <i class="far fa-edit text-emerald-500 mr-2 text-base"></i>
            Write a Story
          </h2>

          <form
            action="/user/posts/add-post"
            method="POST"
            enctype="multipart/form-data"
            id="create-post-form"
          >
            <div class="mb-4">
              <textarea
                name="content"
                rows="3"
                class="w-full p-4 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-emerald-550/10 focus:border-emerald-500 transition-all resize-none text-slate-700 text-sm leading-relaxed"
                placeholder="What is on your mind? Share an inspiring idea..."
                required
              ></textarea>
            </div>

            <div class="mb-4">
              <div class="file-input-wrapper w-full">
                <div
                  id="post-file-dropzone"
                  class="border border-dashed border-slate-250 rounded-xl p-3 text-center hover:border-emerald-400 hover:bg-slate-50 transition-all cursor-pointer bg-slate-50/20"
                >
                  <span class="text-xs font-semibold text-slate-650 flex items-center justify-center space-x-1.5">
                    <i class="far fa-image text-emerald-500"></i>
                    <span>Attach story illustration photo</span>
                  </span>
                  <input
                    type="file"
                    name="image"
                    accept="image/*"
                    id="post-image-input"
                  />
                </div>
              </div>
            </div>

            <button
              type="submit"
              class="w-full bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold py-3 px-4 rounded-xl transition-colors flex items-center justify-center space-x-1.5 shadow-sm shadow-emerald-550/10"
            >
              <i class="fas fa-paper-plane text-[10px]"></i>
              <span>Publish Story</span>
            </button>
          </form>
        </div>
      </div>

      <!-- User's own stories list -->
      <div class="bg-white rounded-3xl border border-slate-100 p-6 sm:p-8 shadow-sm">
        <h2 class="text-lg font-serif-editorial font-bold mb-6 flex items-center text-slate-900 border-b border-slate-100 pb-3">
          <i class="fas fa-book-open text-emerald-600 mr-2.5 text-base"></i>
          Your Published Stories
        </h2>

        <% if (user.posts && user.posts.length === 0) { %>
        <div class="bg-slate-50/40 rounded-2xl p-10 text-center border border-slate-100">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-slate-100 text-slate-400 mb-4">
            <i class="far fa-folder-open text-lg"></i>
          </div>
          <h3 class="text-sm font-semibold text-slate-800 mb-1">No publications yet</h3>
          <p class="text-xs text-slate-400">
            Write your first story in the card above to see it published here
          </p>
        </div>
        <% } else { %>
        <div class="grid gap-6">
          <% if (user.posts.length > 0) { user.posts.forEach(post => { %>
          <div class="border border-slate-100 rounded-2xl overflow-hidden transition-all hover-scale shadow-sm bg-white">
            
            <% if (post.image) { %>
            <div class="aspect-w-16 aspect-h-8 max-h-[300px] overflow-hidden flex items-center bg-slate-50 border-b border-slate-100">
              <img
                src="data:image/jpeg;base64,<%= post.image.toString('base64') %>"
                alt="Story Illustration"
                class="w-full object-cover"
              />
            </div>
            <% } %>

            <div class="p-5">
              <p class="text-slate-700 text-sm sm:text-base leading-relaxed mb-4 whitespace-pre-line font-serif-editorial">
                <%= post.content %>
              </p>

              <div class="flex items-center justify-between border-t border-slate-50 pt-4 mt-2">
                <div class="flex items-center space-x-6">
                  <!-- Likes action -->
                  <button
                    id="<%= post._id %>-like"
                    onclick="likePost('<%= post._id %>')"
                    class="flex items-center text-slate-500 hover:text-rose-500 transition-colors text-xs font-semibold"
                  >
                    <% if (post.likes.indexOf(user._id) !== -1) { %>
                    <i class="fas fa-heart text-rose-500 mr-1.5 animate-pulse"></i>
                    <% } else { %>
                    <i class="far fa-heart text-slate-400 mr-1.5"></i>
                    <% } %>
                    <span id="like-count-<%= post._id %>"><%= post.likes.length || 0 %></span>
                  </button>

                  <!-- Comments link -->
                  <a
                    href="/user/posts/comment/<%= post._id %>"
                    class="flex items-center text-slate-500 hover:text-emerald-600 transition-colors text-xs font-semibold"
                  >
                    <i class="far fa-comment text-emerald-500 mr-1.5"></i>
                    <span><%= post.comment ? post.comment.length : 0 %></span>
                  </a>

                  <!-- Edit story link -->
                  <a
                    href="/user/posts/edit/<%= post._id %>"
                    class="flex items-center text-slate-500 hover:text-indigo-600 transition-colors text-xs font-semibold"
                    title="Edit publication"
                  >
                    <i class="far fa-edit text-indigo-500 mr-1.5"></i>
                    <span>Edit</span>
                  </a>

                  <!-- Delete account account logic handles delete post natively -->
                  <a
                    href="/user/posts/delete/<%= post._id %>"
                    onclick="return confirm('Are you sure you want to delete this story?');"
                    class="flex items-center text-slate-500 hover:text-rose-600 transition-colors text-xs font-semibold"
                    title="Delete publication"
                  >
                    <i class="far fa-trash-alt text-rose-500 mr-1.5"></i>
                    <span>Delete</span>
                  </a>
                </div>

                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider flex items-center">
                  <i class="far fa-clock mr-1.5 text-slate-350"></i>
                  <%= new Date(post.createdAt).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'short', day: 'numeric' }) %>
                </span>
              </div>
            </div>
          </div>
          <% })} %>
        </div>
        <% } %>
      </div>
      
    </div>

    <!-- JavaScript logic -->
    <script>
      async function likePost(postId) {
        try {
          const response = await fetch(`/user/posts/all-posts/like/${postId}`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
          });

          const data = await response.json();
          if (response.ok) {
            const countEl = document.getElementById(`like-count-${postId}`);
            countEl.textContent = data.likes;
            let btn = document.getElementById(`${postId}-like`);
            if (data.liked) {
              btn.innerHTML = `<i class="fas fa-heart text-rose-500 mr-1.5 animate-pulse"></i><span id="like-count-${postId}">${data.likes}</span>`;
            } else {
              btn.innerHTML = `<i class="far fa-heart text-slate-400 mr-1.5"></i> <span id="like-count-${postId}">${data.likes}</span>`;
            }
          } else {
            console.error("Failed to like post");
          }
        } catch (err) {
          console.error("Error:", err);
        }
      }

      // Add interactivity for profile image upload
      const fileInput = document.getElementById("image-input");
      const uploadForm = document.getElementById("update-image-form");

      fileInput.addEventListener("change", (e) => {
        if (e.target.files.length) {
          const fileName = e.target.files[0].name;
          const fileSize = Math.round(e.target.files[0].size / 1024);
          
          const dropzone = fileInput.closest("div");
          dropzone.classList.add("border-emerald-500", "bg-emerald-50/30");
          
          const textEl = dropzone.querySelector("p");
          if (textEl) textEl.textContent = `${fileName} (${fileSize}KB)`;
        }
      });

      uploadForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(uploadForm);

        try {
          const res = await fetch("/user/update-image", {
            method: "POST",
            body: formData,
          });

          const data = await res.json();
          if (data.image) {
            document.getElementById("profile-image").src = data.image;
            fileInput.value = "";
            
            // Reset dropzone styling
            const dropzone = fileInput.closest("div");
            dropzone.classList.remove("border-emerald-500", "bg-emerald-50/30");
            const textEl = dropzone.querySelector("p");
            if (textEl) textEl.textContent = "Choose avatar image";
            
            uploadForm.reset();
            alert("Profile image updated successfully!");
          } else {
            alert("Could not update profile image.");
          }
        } catch (error) {
          console.error("Error uploading image:", error);
          alert("Error uploading image, please try again.");
        }
      });

      // Add file attachment text feedback for story post
      const postImageInput = document.getElementById("post-image-input");
      const postDropzone = document.getElementById("post-file-dropzone");

      postImageInput.addEventListener("change", (e) => {
        if (e.target.files.length) {
          const fileName = e.target.files[0].name;
          postDropzone.classList.add("border-emerald-400", "bg-emerald-50/40");
          postDropzone.querySelector("span").innerHTML = `<i class="fas fa-check text-emerald-600"></i> <span class="text-emerald-700">${fileName} attached</span>`;
        }
      });
      
      // Let dropzone click trigger file selection
      postDropzone.addEventListener("click", () => {
        postImageInput.click();
      });
    </script>
  </body>
</html>
